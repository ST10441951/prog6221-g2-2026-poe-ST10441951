<Window x:Class="CybersecurityChatbotGUI.TaskManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Cybersecurity Tasks" Height="660" Width="600"
        WindowStartupLocation="CenterOwner" Background="#0F172A">

    <!-- Part 3 / Task 1: GUI to view and manage tasks. Mirrors the dark theme of the main
         chat window so the application feels like one cohesive product. -->
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextDim"     Color="#94A3B8"/>
        <SolidColorBrush x:Key="Card"        Color="#1E293B"/>
        <SolidColorBrush x:Key="Border"      Color="#334155"/>
        <SolidColorBrush x:Key="Accent"      Color="#10B981"/>

        <!-- Small rounded button used for the per-task and Add actions -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#334155" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent (green) variant used for the primary "Add" / "Complete" action -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PillButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#10B981" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#059669"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input field with a placeholder: when empty, the box shows its Tag text as a hint
             (a standard WPF VisualBrush technique). -->
        <Style x:Key="FieldBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#10B981"/>
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="Background">
                        <Setter.Value>
                            <VisualBrush AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Text="{Binding Path=Tag,
                                                   RelativeSource={RelativeSource AncestorType=TextBox}}"
                                               Foreground="#64748B" FontSize="13" Margin="10,0,0,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock Text="📋  My Cybersecurity Tasks" Foreground="{StaticResource TextPrimary}"
                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
            <TextBlock x:Name="CountLabel" Text="" Foreground="{StaticResource TextDim}"
                       FontSize="13" VerticalAlignment="Bottom" Margin="10,0,0,2"/>
        </StackPanel>

        <!-- Add-task panel: shows the title + description + reminder fields the brief requires -->
        <Border Grid.Row="1" Background="{StaticResource Card}" CornerRadius="10"
                BorderBrush="{StaticResource Border}" BorderThickness="1" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Add a new task" Foreground="{StaticResource Accent}"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                    <TextBox x:Name="TitleInput" Style="{StaticResource FieldBox}" Margin="0,0,0,6"
                             Tag="Task title (e.g. Review privacy settings)"/>
                    <TextBox x:Name="DescInput" Style="{StaticResource FieldBox}" Margin="0,0,0,6"
                             Tag="Description (optional)"/>
                    <TextBox x:Name="ReminderInput" Style="{StaticResource FieldBox}"
                             Tag="Reminder (optional, e.g. in 3 days / tomorrow)"/>
                </StackPanel>
                <Button Grid.Column="1" Content="➕  Add Task" Style="{StaticResource AccentButton}"
                        VerticalAlignment="Bottom" Padding="16,10" Click="Add_Click"/>
            </Grid>
        </Border>

        <!-- Error banner (hidden unless the database is unreachable) -->
        <Border x:Name="ErrorBanner" Grid.Row="2" Background="#7F1D1D" CornerRadius="8"
                Padding="12,8" Margin="0,0,0,12" Visibility="Collapsed">
            <TextBlock x:Name="ErrorText" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
        </Border>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyState" Grid.Row="3"
                   Text="No tasks yet. Add one above, or ask the chatbot to &quot;add a task&quot;."
                   Foreground="{StaticResource TextDim}" FontSize="13" Margin="2,4,0,10"
                   Visibility="Collapsed"/>

        <!-- Task list -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TasksList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Card}" CornerRadius="10"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                Padding="14" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Title}" Foreground="#F8FAFC"
                                               FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#94A3B8"
                                               FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="{Binding ReminderDisplay}" Foreground="#10B981"
                                                   FontSize="11" Margin="0,0,14,0"/>
                                        <TextBlock Text="{Binding StatusDisplay}" Foreground="#FBBF24"
                                                   FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Button Content="✓ Complete" Style="{StaticResource AccentButton}"
                                            Tag="{Binding Id}" IsEnabled="{Binding CanComplete}"
                                            Margin="0,0,0,6" Click="Complete_Click"/>
                                    <Button Content="🗑 Delete" Style="{StaticResource PillButton}"
                                            Tag="{Binding Id}" Click="Delete_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
