<?xml version="1.0" encoding="utf-8" ?>
<configuration>

	<!--
	Part 3 / Task 1: MySQL Database Integration.
	The connection string lives here (not hard-coded) so the marker can point the app at
	their own MySQL server by editing this single line, no recompilation required.

	The name "CyberChatbotDb" is read by DatabaseConfig.cs via ConfigurationManager.

	Default credentials assume a standard local XAMPP / MySQL install (user "root", no
	password). Change "server", "uid", "pwd" and "database" to match the target machine.

	Reference:
	Oracle (2024). MySqlConnection Connection Strings. [Online] MySQL Connector/NET Developer Guide.
	Available at: https://dev.mysql.com/doc/connector-net/en/connector-net-connections-string.html
	-->
	<connectionStrings>
		<add name="CyberChatbotDb"
		     connectionString="server=localhost;port=3306;uid=root;pwd=;database=cyber_chatbot;SslMode=None;AllowPublicKeyRetrieval=true;"
		     providerName="MySql.Data.MySqlClient" />
	</connectionStrings>

</configuration>
