<Window x:Class="CybersecurityChatbotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber-Shield AI" Height="750" Width="550"
        WindowStartupLocation="CenterScreen" Background="#0F172A" Loaded="Window_Loaded">

    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextDim"     Color="#64748B"/>
        <SolidColorBrush x:Key="BotBubble"   Color="#1E293B"/>
        <SolidColorBrush x:Key="UserBubble"  Color="#10B981"/>
        <SolidColorBrush x:Key="InputBorder" Color="#334155"/>
        <SolidColorBrush x:Key="InputBg"     Color="#1E293B"/>

        <LinearGradientBrush x:Key="ButtonGrad" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#10B981" Offset="0"/>
            <GradientStop Color="#059669" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SuggestionChipBtn" TargetType="Button">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="12,6" Background="#1E293B" CornerRadius="15" BorderBrush="#334155" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#10B981"/>
                                <Setter Property="Foreground" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="4,0,4,15" BorderBrush="#1E293B" BorderThickness="0,0,0,1" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="CYBERSECURITY CHATBOT" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="6" Height="6" Fill="#10B981" Margin="0,0,6,0"/>
                    <TextBlock Text="Secure Connection Active" Foreground="#10B981" FontSize="11" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer x:Name="ChatScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,0,15">
            <ItemsControl x:Name="ChatMessagesControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,8" HorizontalAlignment="{Binding BubbleAlignment}">
                            <Border CornerRadius="12" Padding="14,10" MaxWidth="420" Background="{Binding BubbleBackground}" BorderBrush="#334155" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="{Binding Text}" 
                                               Foreground="{Binding TextColor}" 
                                               FontSize="13" 
                                               FontFamily="{Binding MessageFontFamily}" 
                                               TextWrapping="{Binding MessageWrapping}" 
                                               xml:space="preserve"
                                               LineHeight="20"/>

                                    <TextBlock Text="{Binding Timestamp}" Foreground="{StaticResource TextDim}" FontSize="9" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="8,2" Background="Transparent">
            <StackPanel x:Name="TypingIndicatorRow" Orientation="Horizontal" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock Text="Bot is typing" Foreground="#10B981" FontSize="11" FontFamily="Segoe UI" FontWeight="SemiBold"/>
                <TextBlock Text="..." Foreground="#10B981" FontSize="11" FontWeight="Black"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3">
            <WrapPanel Margin="2,0,0,10" HorizontalAlignment="Left">
                <Button Style="{StaticResource SuggestionChipBtn}" Content="🔑  Passwords" Click="QuickTopic_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="🎣  Phishing" Click="QuickTopic_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="👁️  Privacy" Click="QuickTopic_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="📋  My Tasks" Click="OpenTaskManager_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="🎮  Quiz" Click="OpenQuiz_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="📜  Activity Log" Click="OpenActivityLog_Click"/>
                <Button Style="{StaticResource SuggestionChipBtn}" Content="❓  Help" Click="QuickTopic_Click"/>
            </WrapPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="20" BorderThickness="1" Background="{StaticResource InputBg}" BorderBrush="{StaticResource InputBorder}">
                    <TextBox Name="UserInputBox" Background="Transparent" Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI" FontSize="14" BorderThickness="0" VerticalContentAlignment="Center" Padding="16,10" CaretBrush="#10B981" KeyDown="UserInputBox_KeyDown"/>
                </Border>

                <Button Grid.Column="1" Name="SendButton" Width="40" Height="40" Margin="10,0,0,0" Cursor="Hand" Click="SendButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" CornerRadius="20" Background="{StaticResource ButtonGrad}">
                                <TextBlock Text="➔" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</Window>