<Window x:Class="CybersecurityChatbotGUI.ActivityLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activity Log" Height="620" Width="560"
        WindowStartupLocation="CenterOwner" Background="#0F172A">

    <!-- Part 3 / Task 4: a graphical view of the activity log, themed to match the rest of
         the app. The same log is also viewable in chat via "show activity log". -->
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextDim"     Color="#94A3B8"/>
        <SolidColorBrush x:Key="Card"        Color="#1E293B"/>
        <SolidColorBrush x:Key="Border"      Color="#334155"/>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#334155" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <TextBlock Text="📜  Activity Log" Foreground="{StaticResource TextPrimary}"
                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"/>
            <TextBlock x:Name="CountLabel" Text="" Foreground="{StaticResource TextDim}"
                       FontSize="13" VerticalAlignment="Bottom" Margin="10,0,0,2"/>
        </StackPanel>
        <TextBlock Grid.Row="1" Text="A timestamped record of everything the chatbot has done this session (oldest first)."
                   Foreground="{StaticResource TextDim}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14"/>

        <!-- Empty state -->
        <TextBlock x:Name="EmptyState" Grid.Row="2" VerticalAlignment="Top"
                   Text="No actions recorded yet. Add a task, set a reminder, or play the quiz!"
                   Foreground="{StaticResource TextDim}" FontSize="13" Visibility="Collapsed"/>

        <!-- Entries -->
        <ScrollViewer x:Name="LogScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="EntriesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource Card}" CornerRadius="8"
                                BorderBrush="{StaticResource Border}" BorderThickness="1"
                                Padding="12,10" Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="16"
                                           VerticalAlignment="Top" Margin="0,0,10,0"/>

                                <StackPanel Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="{Binding TimeDisplay}" Foreground="{StaticResource TextDim}"
                                                   FontSize="11" FontFamily="Consolas" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Category}" Foreground="{Binding CategoryColor}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextPrimary}"
                                               FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource PillButton}" Content="↻  Refresh" Margin="0,0,8,0" Click="Refresh_Click"/>
            <Button Style="{StaticResource PillButton}" Content="Close" Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
