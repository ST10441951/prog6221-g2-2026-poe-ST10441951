<Window x:Class="CybersecurityChatbotGUI.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Quiz" Height="680" Width="600"
        WindowStartupLocation="CenterOwner" Background="#0F172A">

    <!-- Part 3 / Task 2: the quiz GUI, themed to match the chat and task windows. -->
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimary" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextDim"     Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent"      Color="#10B981"/>

        <!-- An answer option button: the template binds to the button's Background so the code
             can recolour it green/red after the user answers. -->
        <Style x:Key="OptionButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10"
                                Padding="{TemplateBinding Padding}" BorderBrush="#334155" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#10B981"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary green action button (Next / Play Again) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#10B981" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#059669"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary grey button (Close) -->
        <Style x:Key="PillButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#334155" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header: title + live score -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🎮  Cybersecurity Quiz" Foreground="{StaticResource TextPrimary}"
                       FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" HorizontalAlignment="Left"/>
            <TextBlock x:Name="ScoreLabel" Text="Score: 0" Foreground="{StaticResource Accent}"
                       FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- Progress -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock x:Name="ProgressLabel" Text="Question 1" Foreground="{StaticResource TextDim}"
                       FontSize="12" Margin="0,0,0,6"/>
            <ProgressBar x:Name="QuizProgress" Height="6" Minimum="0" Maximum="1" Value="0"
                         Background="#1E293B" Foreground="#10B981" BorderThickness="0"/>
        </StackPanel>

        <!-- Main area: the question view and the results view share this cell -->
        <Grid Grid.Row="2">

            <!-- QUESTION VIEW -->
            <ScrollViewer x:Name="QuestionArea" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Background="#1E293B" CornerRadius="6" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,10">
                        <TextBlock x:Name="TypeBadge" Text="Multiple choice" Foreground="{StaticResource Accent}"
                                   FontSize="11" FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock x:Name="QuestionText" Text="" Foreground="{StaticResource TextPrimary}"
                               FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,0,0,16"/>

                    <!-- Option buttons are generated in code-behind -->
                    <StackPanel x:Name="OptionsPanel"/>

                    <!-- Feedback after answering -->
                    <Border x:Name="FeedbackPanel" CornerRadius="10" Padding="14" Margin="0,8,0,0" Visibility="Collapsed">
                        <TextBlock x:Name="FeedbackText" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
                    </Border>

                    <Button x:Name="NextButton" Style="{StaticResource AccentButton}" Content="Next  →"
                            HorizontalAlignment="Right" Margin="0,16,0,0" Visibility="Collapsed" Click="Next_Click"/>
                </StackPanel>
            </ScrollViewer>

            <!-- RESULTS VIEW -->
            <StackPanel x:Name="ResultsArea" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <TextBlock Text="Quiz Complete!" Foreground="{StaticResource TextPrimary}"
                           FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ResultScore" Text="" Foreground="{StaticResource Accent}"
                           FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock x:Name="ResultFeedback" Text="" Foreground="{StaticResource TextPrimary}"
                           FontSize="15" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420" Margin="0,12,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0">
                    <Button Style="{StaticResource AccentButton}" Content="↻  Play Again"
                            Margin="0,0,10,0" Click="PlayAgain_Click"/>
                    <Button Style="{StaticResource PillButton}" Content="Close" Click="Close_Click"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
